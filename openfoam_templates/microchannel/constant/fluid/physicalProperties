FoamFile
{
    format      ascii;
    class       dictionary;
    location    "constant/fluid";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       __MOL_WEIGHT__;
    }
    equationOfState
    {
        rho             __RHO__;
    }
    thermodynamics
    {
        Cp              __CP__;
        Hf              0;
    }
    transport
    {
        mu              __MU__;
        Pr              __PR__;
    }
}

