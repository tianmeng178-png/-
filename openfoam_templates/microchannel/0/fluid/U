FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0/fluid";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (__INLET_VELOCITY__ 0 0);

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    fluidInlet
    {
        type            fixedValue;
        value           uniform (__INLET_VELOCITY__ 0 0);
    }
    fluidOutlet
    {
        type            pressureInletOutletVelocity;
        value           $internalField;
    }
    fluidWalls
    {
        type            noSlip;
    }
    fluid_to_solid
    {
        type            noSlip;
    }
}

